@model CinemaApp.Models.FilmActor

<h1>Edit</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="FilmId" />
    <input type="hidden" asp-for="ActorId" />

    <div class="form-group">
        <label>Film</label>
        <select asp-for="FilmId"
                class="form-control"
                asp-items="ViewBag.FilmId"></select>
    </div>

    <div class="form-group">
        <label>Actor</label>
        <select asp-for="ActorId"
                class="form-control"
                asp-items="ViewBag.ActorId"></select>
    </div>

    <br />

    <input type="submit" value="Save" class="btn btn-primary" />
    <a asp-action="Index">Back to List</a>
</form>