@model CinemaApp.Models.FilmActor

<h1>Delete</h1>

<h3>Are you sure you want to delete this link?</h3>

<hr />

<dl class="row">
    <dt class="col-sm-2">Film</dt>
    <dd class="col-sm-10">@Model.Film.Title</dd>

    <dt class="col-sm-2">Actor</dt>
    <dd class="col-sm-10">@Model.Actor.FirstName @Model.Actor.LastName</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="FilmId" />
    <input type="hidden" asp-for="ActorId" />

    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>