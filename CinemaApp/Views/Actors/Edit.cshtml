@model CinemaApp.Models.Actor

<h1>Edit Actor</h1>

<hr />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ActorId" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="BirthDate"></label>
        <input asp-for="BirthDate" type="date" class="form-control" />
        <span asp-validation-for="BirthDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Nationality"></label>
        <input asp-for="Nationality" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Biography"></label>
        <textarea asp-for="Biography" class="form-control"></textarea>
    </div>

    <br />
    <input type="submit" value="Next" class="btn btn-primary" />
</form>

<br />
<a asp-action="Index">Back to List</a>