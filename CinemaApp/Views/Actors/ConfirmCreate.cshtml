@model CinemaApp.Models.Actor

<h1>Confirm Create</h1>

<hr />

<dl class="row">
    <dt class="col-sm-2">First Name</dt>
    <dd class="col-sm-10">@Model.FirstName</dd>

    <dt class="col-sm-2">Last Name</dt>
    <dd class="col-sm-10">@Model.LastName</dd>

    <dt class="col-sm-2">Birth Date</dt>
    <dd class="col-sm-10">@Model.BirthDate?.ToShortDateString()</dd>

    <dt class="col-sm-2">Nationality</dt>
    <dd class="col-sm-10">@Model.Nationality</dd>

    <dt class="col-sm-2">Biography</dt>
    <dd class="col-sm-10">@Model.Biography</dd>
</dl>

<form asp-action="ConfirmCreate">
    <button type="submit" class="btn btn-success">Confirm</button>
    <a asp-action="Create" class="btn btn-secondary">Back</a>
</form>
