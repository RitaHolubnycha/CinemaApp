@model CinemaApp.Models.Film

<h1>Film Details</h1>

<div>
    <h4>Film</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Release Date</dt>
        <dd class="col-sm-10">@(Model.ReleaseDate?.ToShortDateString())</dd>

        <dt class="col-sm-2">Genre</dt>
        <dd class="col-sm-10">@Model.Genre</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Actors</dt>
        <dd class="col-sm-10">
            @if (Model.FilmActors != null && Model.FilmActors.Any())
            {
                <ul>
                    @foreach (var fa in Model.FilmActors)
                    {
                        <li>
                            @fa.Actor.FirstName @fa.Actor.LastName

                            <form asp-controller="FilmActors"
                                  asp-action="Delete"
                                  method="post"
                                  style="display:inline">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="filmId" value="@fa.FilmId" />
                                <input type="hidden" name="actorId" value="@fa.ActorId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                                <button type="submit" class="btn btn-sm btn-danger">
                                    Remove
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            }
            else
            {
                <span>No actors assigned</span>
            }
        </dd>
        <a asp-controller="FilmActors"
           asp-action="Create"
           asp-route-filmId="@Model.FilmId"
           asp-route-returnUrl="@Context.Request.Path"
           class="btn btn-success">
            Add Actor
        </a>
    </dl>
</div>

<a asp-action="Index" class="btn btn-secondary">Back to List</a>